# VibeDigest Environment Configuration Template
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# --- Local Development Overrides ---
NEXT_PUBLIC_API_URL=http://localhost:16081
LANGGRAPH_API_URL=http://localhost:8123
BACKEND_API_URL=http://localhost:16081
FRONTEND_URL=http://localhost:3000
COGNITION_SEQUENTIAL=true
COGNITION_DELAY=2
LOG_LEVEL=DEBUG
DEV_AUTH_BYPASS=true

# --- LLM Provider ---
# Options: "openai" (default), "openrouter" (recommended for local dev), "custom"
LLM_PROVIDER=openrouter
# OPENAI_API_KEY=           # Only needed for openai/custom provider
# OPENAI_BASE_URL=          # Only needed for custom provider
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
DATABASE_URL=postgresql://postgres:your-password@your-host:6543/postgres

# --- Payment (Optional) ---
# CREEM_API_KEY=
# CREEM_WEBHOOK_SECRET=
# COINBASE_API_KEY=
# COINBASE_WEBHOOK_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Email (Optional) ---
# RESEND_API_KEY=

# --- Transcript Acceleration (Optional) ---
# SUPADATA_API_KEY=                 # Single key or comma-separated for round-robin rotation: key1,key2,key3

# --- yt-dlp Cookies (Optional) ---
# YTDLP_COOKIES=/app/yt-cookies.txt
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES_PROFILE=Default

# --- Observability (Optional) ---
# LANGCHAIN_API_KEY=
# LANGSMITH_API_KEY=
