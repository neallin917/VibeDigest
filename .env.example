# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom OpenAI Base URL (for proxy or alternative endpoints)
OPENAI_BASE_URL=https://api.openai.com/v1

# Server Configuration (Optional)
HOST=0.0.0.0
PORT=8000

# Whisper Model Configuration (Optional)
# Options: tiny, base, small, medium, large
WHISPER_MODEL_SIZE=base

# Supabase Configuration (Required for v2)
# Create a project at https://supabase.com
# URL: Project Settings -> API -> Project URL
SUPABASE_URL=your_supabase_project_url

# Anon Key: Project Settings -> API -> Project API keys -> anon public
# Used by the Frontend Client
SUPABASE_KEY=your_supabase_anon_key

# Service Role Key: Project Settings -> API -> Project API keys -> service_role (secret)
# Used by the Backend Worker (Never expose this to the client!)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
