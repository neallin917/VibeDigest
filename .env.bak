# ==============================================
# VibeDigest Master Configuration (Single Source of Truth)
# ==============================================

# ----------------------------------------------
# Ports (Docker Host Mappings)
# ----------------------------------------------
# These define which ports are exposed on your localhost.
# Change these here, and they propagate to Docker and Frontend proxies.

BACKEND_PORT=16081
LANGGRAPH_PORT=8123
FRONTEND_PORT=3000
DB_PORT=15432
REDIS_PORT=16379

# ----------------------------------------------
# Internal Container Ports (Do not usually change)
# ----------------------------------------------
BACKEND_CONTAINER_PORT=8000
LANGGRAPH_CONTAINER_PORT=8000

# ----------------------------------------------
# Derived URLs (For Frontend/Client usage)
# ----------------------------------------------
# These are constructed from the ports above.
# Frontend applications use these to reach services.

NEXT_PUBLIC_API_URL=http://localhost:16081
LANGGRAPH_API_URL=http://localhost:8123
BACKEND_API_URL=http://localhost:16081

# ----------------------------------------------
# Service Configuration
# ----------------------------------------------
PROJECT_NAME=vibedigest
COMPOSE_PROJECT_NAME=vibedigest
