# ==============================================
# VibeDigest Backend Configuration (Template)
# ==============================================

# ----------------------------------------------
# 1. LLM Provider Configuration (Choose One)
# ----------------------------------------------

# Option A: Real OpenAI (Default)
# -----------------------------------
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Option B: Custom / Local / Vercel AI SDK Compatible
# (Uncomment this block to switch providers)
# -----------------------------------
# LLM_PROVIDER=custom
# OPENAI_API_KEY=your-local-key-or-dummy
# OPENAI_BASE_URL=http://127.0.0.1:8045/v1
#
# # Model Aliases (Map generic names to provider-specific names)
# MODEL_ALIAS_GPT_4O=openai/gpt-4o
# MODEL_ALIAS_GPT_4O_MINI=openai/gpt-4o-mini
# MODEL_ALIAS_COMPREHENSION=openai/gpt-4o

# ----------------------------------------------
# 2. Database & Core Services
# ----------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
# SERVICE ROLE KEY (Required for Backend Operations)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
# Direct Postgres Connection (Pooler)
DATABASE_URL=postgresql://postgres.user:password@aws-0-region.pooler.supabase.com:6543/postgres

# ----------------------------------------------
# 3. Third-Party Integrations
# ----------------------------------------------
# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
FEEDBACK_TO_EMAIL=admin@example.com
FEEDBACK_FROM_EMAIL=noreply@example.com

# Coinbase (Crypto Payment)
COINBASE_API_KEY=
COINBASE_WEBHOOK_SECRET=

# Creem (Fiat Payment)
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_API_BASE=https://api.creem.io

# Stripe (Legacy/Alternative)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Supadata
SUPADATA_API_KEY=

# ----------------------------------------------
# 4. Observability & Logging
# ----------------------------------------------
# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Langfuse
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# LangSmith / LangChain Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=VibeDigest
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=VibeDigest

# Logging
LOG_LEVEL=INFO

# ----------------------------------------------
# 5. Application Settings
# ----------------------------------------------
FRONTEND_URL=http://localhost:3000
OPENAI_SUMMARY_MATCH_THRESHOLD=4.0
SUMMARY_STRATEGY=v2_classified
MOCK_MODE=false